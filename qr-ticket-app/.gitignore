# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js build output
/.next/
/out/
/build

# testing
/coverage
/.nyc_output

# env files — .env.local contains secrets, NEVER commit it
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example IS intentionally committed (no secrets)

# typescript
*.tsbuildinfo
next-env.d.ts

# package managers — using pnpm, so npm lockfile is redundant
package-lock.json

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# vercel
.vercel

# misc certs / keys
*.pem
*.key
*.crt

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.idea/
*.suo
*.user
*.swp
*.swo

# Supabase local dev (Docker volumes — not needed in repo)
/supabase/.branches
/supabase/.temp
