# Supabase — get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to client or commit the real value
SUPABASE_SERVICE_ROLE_KEY=

# App URL (update for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# QR payload HMAC signing secret — generate with: openssl rand -hex 32
# Without this, HMAC signing is skipped (dev only). MUST be set in production.
HMAC_SECRET=
